<mxfile>
  <diagram name="PomodoroStateMachine">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════════════════════════════════════════════════
             INITIAL PSEUDO-STATE  (filled black circle, x=80, y=100)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="2" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="80" y="94" width="32" height="32" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STATE: IDLE  (x=200, y=60)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="3" value="IDLE" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STATE: RUNNING  (x=450, y=60)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="4" value="RUNNING" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="60" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STATE: PAUSED  (x=450, y=220)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="5" value="PAUSED" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="220" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STATE: COMPLETED  (terminal, x=700, y=60)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="6" value="COMPLETED" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fontSize=14;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="700" y="60" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STATE: CANCELLED  (terminal, x=700, y=220)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="7" value="CANCELLED" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fontSize=14;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="700" y="220" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             FINAL STATE  (circle with inner filled circle, x=940, y=137)
        ════════════════════════════════════════════════════════════════ -->
        <!-- outer ring -->
        <mxCell id="8" value="" style="ellipse;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="930" y="127" width="48" height="48" as="geometry"/>
        </mxCell>
        <!-- inner filled dot -->
        <mxCell id="9" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="942" y="139" width="24" height="24" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             TRANSITIONS
        ════════════════════════════════════════════════════════════════ -->

        <!-- Initial → IDLE -->
        <mxCell id="10" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IDLE → RUNNING: Start() -->
        <mxCell id="11" value="Start()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="390" y="82" as="sourcePoint"/>
            <mxPoint x="450" y="82" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- RUNNING → PAUSED: Pause() -->
        <mxCell id="12" value="Pause()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RUNNING → COMPLETED: Complete() -->
        <mxCell id="13" value="Complete()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RUNNING → CANCELLED: Cancel() -->
        <mxCell id="14" value="Cancel()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=1;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="4" target="7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="140"/>
              <mxPoint x="680" y="140"/>
              <mxPoint x="680" y="250"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- PAUSED → RUNNING: Resume() -->
        <mxCell id="15" value="Resume()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;entryX=0.5;entryY=1;endArrow=block;endFill=1;" edge="1" source="5" target="4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="205"/>
              <mxPoint x="540" y="205"/>
              <mxPoint x="540" y="135"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- PAUSED → CANCELLED: Cancel() -->
        <mxCell id="16" value="Cancel()" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="5" target="7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- COMPLETED → Final state -->
        <mxCell id="17" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="6" target="8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CANCELLED → Final state -->
        <mxCell id="18" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=block;endFill=1;" edge="1" source="7" target="8" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="250"/>
              <mxPoint x="920" y="250"/>
              <mxPoint x="920" y="151"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             GUARD: COMPLETED dashed self-loop (errInvalidTransition)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="19" value="Start/Pause/Resume/Cancel → errInvalidTransition" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;entryX=1;entryY=0;endArrow=block;endFill=1;dashed=1;fontSize=10;" edge="1" source="6" target="6" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="20"/>
              <mxPoint x="870" y="20"/>
              <mxPoint x="870" y="60"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             GUARD: CANCELLED dashed self-loop (errInvalidTransition)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="20" value="Start/Pause/Resume/Cancel → errInvalidTransition" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=1;entryY=1;endArrow=block;endFill=1;dashed=1;fontSize=10;" edge="1" source="7" target="7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="320"/>
              <mxPoint x="870" y="320"/>
              <mxPoint x="870" y="280"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
