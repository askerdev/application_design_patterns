<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://taskflow.app/bpmn"
             id="Definitions_BP1">

  <!-- BP1: Reminder Notification Lifecycle -->

  <dataStore id="DS_Reminders" name="reminders"/>

  <collaboration id="Collaboration_BP1">
    <participant id="Participant_User"     name="Пользователь"    processRef="Process_User"/>
    <participant id="Participant_TaskFlow" name="TaskFlow"         processRef="Process_TaskFlow"/>
    <participant id="Participant_Telegram" name="Telegram Bot API" processRef="Process_Telegram"/>

    <messageFlow id="MF_1" name="данные напоминания"
                 sourceRef="Task_GetReminderData" targetRef="Task_CreateReminder"/>
    <messageFlow id="MF_2" name="сообщение"
                 sourceRef="Task_SendToTelegram"  targetRef="Task_ProcessMessage"/>
    <messageFlow id="MF_3" name="ответ API"
                 sourceRef="Task_ProcessMessage"  targetRef="Task_GetApiResponse"/>
  </collaboration>

  <process id="Process_User" name="Пользователь" isExecutable="false">
    <startEvent id="Start_User" name="Создаётся напоминание">
      <outgoing>SF_U1</outgoing>
    </startEvent>
    <task id="Task_GetReminderData" name="Получить данные напоминания">
      <incoming>SF_U1</incoming>
    </task>
    <sequenceFlow id="SF_U1" sourceRef="Start_User" targetRef="Task_GetReminderData"/>
  </process>

  <process id="Process_TaskFlow" name="TaskFlow" isExecutable="false">
    <task id="Task_CreateReminder" name="Создать напоминание (EntityFactory)">
      <outgoing>SF_T1</outgoing>
    </task>
    <dataStoreReference id="DSR_Reminders" name="reminders" dataStoreRef="DS_Reminders"/>

    <task id="Task_SaveToDB" name="Сохранить в БД [reminders] PENDING">
      <incoming>SF_T1</incoming>
      <outgoing>SF_T2</outgoing>
      <dataOutputAssociation id="DOA_SaveReminder">
        <targetRef>DSR_Reminders</targetRef>
      </dataOutputAssociation>
    </task>
    <intermediateCatchEvent id="ICE_Tick" name="30 сек тик">
      <incoming>SF_T2</incoming>
      <outgoing>SF_T3</outgoing>
      <timerEventDefinition id="Timer_Tick">
        <timeCycle xsi:type="tFormalExpression">R/PT30S</timeCycle>
      </timerEventDefinition>
    </intermediateCatchEvent>
    <task id="Task_CheckAndNotify" name="CheckAndNotify() — найти PENDING где time≤now">
      <incoming>SF_T3</incoming>
      <outgoing>SF_T4</outgoing>
      <dataInputAssociation id="DIA_CheckReminder">
        <sourceRef>DSR_Reminders</sourceRef>
      </dataInputAssociation>
    </task>
    <task id="Task_SendToTelegram" name="Отправить в Telegram (TelegramNotifier)">
      <incoming>SF_T4</incoming>
      <outgoing>SF_T5</outgoing>
    </task>
    <task id="Task_GetApiResponse" name="Получить ответ API">
      <incoming>SF_T5</incoming>
      <outgoing>SF_T6</outgoing>
    </task>
    <exclusiveGateway id="GW_Success" name="Успешно?">
      <incoming>SF_T6</incoming>
      <outgoing>SF_T7_yes</outgoing>
      <outgoing>SF_T7_no</outgoing>
    </exclusiveGateway>
    <task id="Task_MarkSent" name="MarkAsSent() → SENT">
      <incoming>SF_T7_yes</incoming>
      <outgoing>SF_T8</outgoing>
    </task>
    <endEvent id="End_TF_Done" name="Завершено">
      <incoming>SF_T8</incoming>
    </endEvent>
    <sequenceFlow id="SF_T7_no"  name="Нет" sourceRef="GW_Success"        targetRef="Task_SaveToDB"/>
    <sequenceFlow id="SF_T1"                sourceRef="Task_CreateReminder" targetRef="Task_SaveToDB"/>
    <sequenceFlow id="SF_T2"                sourceRef="Task_SaveToDB"       targetRef="ICE_Tick"/>
    <sequenceFlow id="SF_T3"                sourceRef="ICE_Tick"            targetRef="Task_CheckAndNotify"/>
    <sequenceFlow id="SF_T4"                sourceRef="Task_CheckAndNotify" targetRef="Task_SendToTelegram"/>
    <sequenceFlow id="SF_T5"                sourceRef="Task_SendToTelegram" targetRef="Task_GetApiResponse"/>
    <sequenceFlow id="SF_T6"                sourceRef="Task_GetApiResponse" targetRef="GW_Success"/>
    <sequenceFlow id="SF_T7_yes" name="Да"  sourceRef="GW_Success"         targetRef="Task_MarkSent"/>
    <sequenceFlow id="SF_T8"                sourceRef="Task_MarkSent"       targetRef="End_TF_Done"/>
  </process>

  <process id="Process_Telegram" name="Telegram Bot API" isExecutable="false">
    <task id="Task_ProcessMessage" name="Обработать сообщение"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_BP1">

      <bpmndi:BPMNShape id="Shape_Part_User" bpmnElement="Participant_User" isHorizontal="true">
        <omgdc:Bounds x="160" y="80" width="1690" height="200"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Part_TaskFlow" bpmnElement="Participant_TaskFlow" isHorizontal="true">
        <omgdc:Bounds x="160" y="280" width="1690" height="250"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Part_Telegram" bpmnElement="Participant_Telegram" isHorizontal="true">
        <omgdc:Bounds x="160" y="530" width="1690" height="200"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Start_User" bpmnElement="Start_User">
        <omgdc:Bounds x="232" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="208" y="205" width="84" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GetReminderData" bpmnElement="Task_GetReminderData">
        <omgdc:Bounds x="330" y="140" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_CreateReminder" bpmnElement="Task_CreateReminder">
        <omgdc:Bounds x="330" y="325" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_SaveToDB" bpmnElement="Task_SaveToDB">
        <omgdc:Bounds x="590" y="325" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ICE_Tick" bpmnElement="ICE_Tick">
        <omgdc:Bounds x="852" y="347" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="833" y="390" width="74" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_CheckAndNotify" bpmnElement="Task_CheckAndNotify">
        <omgdc:Bounds x="950" y="325" width="220" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_SendToTelegram" bpmnElement="Task_SendToTelegram">
        <omgdc:Bounds x="1230" y="325" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GetApiResponse" bpmnElement="Task_GetApiResponse">
        <omgdc:Bounds x="1230" y="430" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_Success" bpmnElement="GW_Success" isMarkerVisible="true">
        <omgdc:Bounds x="1500" y="340" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1487" y="397" width="76" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_MarkSent" bpmnElement="Task_MarkSent">
        <omgdc:Bounds x="1620" y="325" width="180" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_End_TF_Done" bpmnElement="End_TF_Done">
        <omgdc:Bounds x="1812" y="347" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1800" y="390" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- DataStoreReference: reminders table (cylinder) inside TaskFlow pool -->
      <bpmndi:BPMNShape id="Shape_DSR_Reminders" bpmnElement="DSR_Reminders">
        <omgdc:Bounds x="825" y="435" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="813" y="492" width="74" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ProcessMessage" bpmnElement="Task_ProcessMessage">
        <omgdc:Bounds x="1230" y="575" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Data association edges -->
      <bpmndi:BPMNEdge id="Edge_DOA_SaveReminder" bpmnElement="DOA_SaveReminder">
        <omgdi:waypoint x="690" y="405"/>
        <omgdi:waypoint x="850" y="435"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_DIA_CheckReminder" bpmnElement="DIA_CheckReminder">
        <omgdi:waypoint x="850" y="435"/>
        <omgdi:waypoint x="1060" y="405"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_U1" bpmnElement="SF_U1">
        <omgdi:waypoint x="268" y="180"/>
        <omgdi:waypoint x="330" y="180"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T1" bpmnElement="SF_T1">
        <omgdi:waypoint x="530" y="365"/>
        <omgdi:waypoint x="590" y="365"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T2" bpmnElement="SF_T2">
        <omgdi:waypoint x="790" y="365"/>
        <omgdi:waypoint x="852" y="365"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T3" bpmnElement="SF_T3">
        <omgdi:waypoint x="888" y="365"/>
        <omgdi:waypoint x="950" y="365"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T4" bpmnElement="SF_T4">
        <omgdi:waypoint x="1170" y="365"/>
        <omgdi:waypoint x="1230" y="365"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T5" bpmnElement="SF_T5">
        <omgdi:waypoint x="1330" y="405"/>
        <omgdi:waypoint x="1330" y="430"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T6" bpmnElement="SF_T6">
        <omgdi:waypoint x="1430" y="470"/>
        <omgdi:waypoint x="1525" y="470"/>
        <omgdi:waypoint x="1525" y="390"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T7_yes" bpmnElement="SF_T7_yes">
        <omgdi:waypoint x="1550" y="365"/>
        <omgdi:waypoint x="1620" y="365"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1567" y="348" width="20" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T7_no" bpmnElement="SF_T7_no">
        <omgdi:waypoint x="1525" y="340"/>
        <omgdi:waypoint x="1525" y="305"/>
        <omgdi:waypoint x="690" y="305"/>
        <omgdi:waypoint x="690" y="325"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1094" y="288" width="20" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SF_T8" bpmnElement="SF_T8">
        <omgdi:waypoint x="1800" y="365"/>
        <omgdi:waypoint x="1812" y="365"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MF_1" bpmnElement="MF_1">
        <omgdi:waypoint x="430" y="220"/>
        <omgdi:waypoint x="430" y="325"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="435" y="265" width="90" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MF_2" bpmnElement="MF_2">
        <omgdi:waypoint x="1330" y="405"/>
        <omgdi:waypoint x="1330" y="575"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1336" y="480" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MF_3" bpmnElement="MF_3">
        <omgdi:waypoint x="1330" y="655"/>
        <omgdi:waypoint x="1330" y="510"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1336" y="572" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
